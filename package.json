{
  "name": "livesupport-widget",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "esbuild src/widget.ts --bundle --watch --outfile=public/widget.js --platform=browser --format=iife --target=es2018 --sourcemap",

    "build": "esbuild src/widget.ts --bundle --minify --outfile=public/widget.min.js --platform=browser --format=iife --target=es2018",

    "start": "serve -s public -l $PORT"
  },
  "dependencies": {
    "serve": "^14.2.6",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "typescript": "^5.8.3"
  }
}